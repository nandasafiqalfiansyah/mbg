---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Dashboard | PanenLangsung"
  description="Dashboard pengguna PanenLangsung untuk memantau transaksi hasil panen dan aktivitas toko petani."
>
  <section class="px-5 py-24 sm:py-28">
    <div class="w-full max-w-[1240px] mx-auto">
      <div class="mt-16 mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <p class="text-sm uppercase tracking-[0.2em] text-black/60">Dashboard PanenLangsung</p>
          <h1 class="text-3xl font-medium">Ringkasan Akun</h1>
          <p id="user-email" class="text-black/70 mt-1">Memuat data pengguna...</p>
        </div>
        <button id="logout-btn" class="px-6 py-3 rounded-[14px] border border-black bg-white hover:bg-black hover:text-white transition">Logout</button>
      </div>

      <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-5 mb-8">
        <div class="rounded-[20px] border border-black/10 bg-[#F3F3F3] p-6">
          <p class="text-sm text-black/60">Total Toko Petani Aktif</p>
          <p class="text-3xl font-medium mt-2">128</p>
        </div>
        <div class="rounded-[20px] border border-black/10 bg-[#F3F3F3] p-6">
          <p class="text-sm text-black/60">Pesanan Hari Ini</p>
          <p class="text-3xl font-medium mt-2">46.200</p>
        </div>
        <div class="rounded-[20px] border border-black/10 bg-[#F3F3F3] p-6">
          <p class="text-sm text-black/60">Pesanan Dalam Pengiriman</p>
          <p class="text-3xl font-medium mt-2">12</p>
        </div>
        <div class="rounded-[20px] border border-black/10 bg-[#F3F3F3] p-6">
          <p class="text-sm text-black/60">Langganan Aktif Minggu Ini</p>
          <p class="text-3xl font-medium mt-2">34</p>
        </div>
      </div>

      <div class="rounded-[20px] border border-black/10 bg-white p-6">
        <h2 class="text-xl font-medium mb-3">Akses Cepat</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 text-sm">
          <a href="/" class="rounded-[14px] border border-black/20 p-4 hover:bg-[#F3F3F3]">Kembali ke Beranda</a>
          <a href="/#catalog" class="rounded-[14px] border border-black/20 p-4 hover:bg-[#F3F3F3]">Lihat Katalog Produk</a>
          <a href="/#sponsors" class="rounded-[14px] border border-black/20 p-4 hover:bg-[#F3F3F3]">Lihat Mitra Platform</a>
        </div>
      </div>
    </div>
  </section>

  <script type="module">
    import { createClient } from "@supabase/supabase-js";

    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseKey = import.meta.env.PUBLIC_SUPABASE_KEY;
    const LOCAL_SESSION_KEY = "panenlangsung_session";
    const AUTH_COOKIE = "pl_auth";
    const userEmailEl = document.getElementById("user-email");
    const logoutBtn = document.getElementById("logout-btn");

    async function clearAuthCookie() {
      try {
        await fetch("/api/session", { method: "DELETE" });
      } catch {
        // Fallback to client cookie when API is not reachable.
      }
      document.cookie = `${AUTH_COOKIE}=; Path=/; Max-Age=0; SameSite=Lax`;
    }

    if (!supabaseUrl || !supabaseKey) {
      const raw = localStorage.getItem(LOCAL_SESSION_KEY);

      if (!raw) {
        window.location.href = "/login";
      } else {
        const session = JSON.parse(raw);
        const email = session.email || "Pengguna PanenLangsung";
        if (userEmailEl) {
          userEmailEl.textContent = `Login sebagai: ${email}`;
        }
      }

      logoutBtn?.addEventListener("click", async () => {
        localStorage.removeItem(LOCAL_SESSION_KEY);
        await clearAuthCookie();
        window.location.href = "/login";
      });
    } else {
      const supabase = createClient(supabaseUrl, supabaseKey);
      const rawLocalSession = localStorage.getItem(LOCAL_SESSION_KEY);

      const { data } = await supabase.auth.getSession();

      if (!data.session) {
        if (!rawLocalSession) {
          window.location.href = "/login";
        } else {
          const localSession = JSON.parse(rawLocalSession);
          const email = localSession.email || "Pengguna PanenLangsung";
          if (userEmailEl) {
            userEmailEl.textContent = `Login sebagai: ${email}`;
          }
        }
      } else {
        const email = data.session.user.email || "Pengguna PanenLangsung";
        localStorage.setItem(
          LOCAL_SESSION_KEY,
          JSON.stringify({ email: String(email), loginAt: new Date().toISOString() })
        );
        if (userEmailEl) {
          userEmailEl.textContent = `Login sebagai: ${email}`;
        }
      }

      logoutBtn?.addEventListener("click", async () => {
        await supabase.auth.signOut();
        localStorage.removeItem(LOCAL_SESSION_KEY);
        await clearAuthCookie();
        window.location.href = "/login";
      });
    }
  </script>
</MainLayout>
