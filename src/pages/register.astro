---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Register | PanenLangsung"
  description="Daftar akun PanenLangsung untuk mulai menjual atau membeli hasil panen langsung."
>
  <section class="px-5 py-24 sm:py-28">
    <div class="w-full max-w-[1240px] mx-auto">
      <div class="max-w-xl mx-auto bg-[#F3F3F3] rounded-[30px] border border-black/10 p-8 sm:p-10 mt-16">
        <p class="text-sm uppercase tracking-[0.2em] text-black/60 mb-2">Registrasi Akun PanenLangsung</p>
        <h1 class="text-3xl font-medium mb-2">Buat Akun Baru</h1>
        <p class="text-black/70 mb-8">Setelah registrasi berhasil, Anda bisa langsung masuk ke dashboard.</p>

        <form id="register-form" class="space-y-4">
          <div>
            <label for="name" class="block text-sm mb-2">Nama Lengkap</label>
            <input id="name" type="text" required placeholder="Nama pengguna" class="w-full px-4 py-3 border border-black rounded-[14px] bg-white outline-none" />
          </div>
          <div>
            <label for="email" class="block text-sm mb-2">Email</label>
            <input id="email" type="email" required placeholder="nama@panenlangsung.id" class="w-full px-4 py-3 border border-black rounded-[14px] bg-white outline-none" />
          </div>
          <div>
            <label for="password" class="block text-sm mb-2">Password</label>
            <input id="password" type="password" required placeholder="Minimal 6 karakter" class="w-full px-4 py-3 border border-black rounded-[14px] bg-white outline-none" />
          </div>
          <button id="register-btn" type="submit" class="btn-primary w-full">Daftar</button>
        </form>

        <div id="register-message" class="mt-4 hidden rounded-[14px] border px-4 py-3 text-sm" role="status" aria-live="polite"></div>

        <p class="mt-6 text-sm text-black/70 text-center">
          Sudah punya akun?
          <a href="/login" class="underline">Masuk di sini</a>
        </p>
      </div>
    </div>
  </section>

  <script type="module">
    import { createClient } from "@supabase/supabase-js";

    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseKey = import.meta.env.PUBLIC_SUPABASE_KEY;
    const LOCAL_SESSION_KEY = "panenlangsung_session";
    const AUTH_COOKIE = "pl_auth";

    const messageEl = document.getElementById("register-message");
    const form = document.getElementById("register-form");
    const registerBtn = document.getElementById("register-btn");

    function saveLocalSession(email, name) {
      localStorage.setItem(
        LOCAL_SESSION_KEY,
        JSON.stringify({ email: String(email), name: String(name || "Pengguna PanenLangsung"), loginAt: new Date().toISOString() })
      );
    }

    function setAuthCookie() {
      document.cookie = `${AUTH_COOKIE}=1; Path=/; Max-Age=86400; SameSite=Lax`;
    }

    async function persistAuthCookie() {
      try {
        await fetch("/api/session", { method: "POST" });
      } catch {
        // Fallback to client cookie when API is not reachable.
      }
      setAuthCookie();
    }

    async function completeRegister(email, name) {
      await persistAuthCookie();
      saveLocalSession(email || "Pengguna PanenLangsung", name || "Pengguna PanenLangsung");
      window.location.href = "/dashboard";
    }

    function showNotice(type, message) {
      if (!messageEl) return;

      const classes = {
        success: "mt-4 rounded-[14px] border border-emerald-300 bg-emerald-50 px-4 py-3 text-sm text-emerald-800",
        error: "mt-4 rounded-[14px] border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-700",
        info: "mt-4 rounded-[14px] border border-zinc-300 bg-white px-4 py-3 text-sm text-zinc-700",
      };

      messageEl.className = classes[type] || classes.info;
      messageEl.textContent = message;
    }

    if (!supabaseUrl || !supabaseKey) {
      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const name = document.getElementById("name")?.value;
        const email = document.getElementById("email")?.value;
        const password = document.getElementById("password")?.value;

        if (!email || !password) return;

        if (registerBtn) registerBtn.textContent = "Memproses...";
        await completeRegister(email, name);
      });

      if (messageEl) {
        showNotice("info", "Mode lokal aktif. Registrasi langsung diarahkan ke dashboard.");
      }
    } else {
      const supabase = createClient(supabaseUrl, supabaseKey);

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const name = document.getElementById("name")?.value;
        const email = document.getElementById("email")?.value;
        const password = document.getElementById("password")?.value;

        if (!email || !password) return;

        if (registerBtn) registerBtn.textContent = "Memproses...";

        const { data, error } = await supabase.auth.signUp({
          email: String(email),
          password: String(password),
          options: {
            data: { full_name: String(name || "Pengguna PanenLangsung") },
            emailRedirectTo: `${window.location.origin}/dashboard`,
          },
        });

        if (error) {
          showNotice("info", `Supabase register gagal (${error.message}). Menggunakan mode lokal.`);
          await completeRegister(email, name);
          return;
        }

        // Keep UX consistent: after successful register, allow direct access to dashboard.
        if (data.session) {
          await completeRegister(email, name);
          return;
        }

        const { error: signInError } = await supabase.auth.signInWithPassword({
          email: String(email),
          password: String(password),
        });

        if (signInError) {
          await completeRegister(email, name);
          return;
        }

        await completeRegister(email, name);
        return;
      });
    }
  </script>
</MainLayout>
