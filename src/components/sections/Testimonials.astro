    <SectionTitle
      sectionTitle="Testimoni Pengguna"
      description="Cerita dari petani dan konsumen setelah menggunakan PanenLangsung untuk transaksi hasil panen harian."
    />
    <div class="rounded-[45px] bg-dark mb-[150px] text-gray">
      <SwiperSlider />
    </div>
  </div>
</Section>
