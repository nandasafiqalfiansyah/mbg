---
import { Image } from "astro:assets";
import Card from "../ui/Card.astro";
import Section from "./Section.astro";

const cards = [
  {
    index: 0,
    title:
      "Di Bandung, kelompok petani sayur menjual produk harian langsung ke pelanggan rumah tangga, sehingga margin petani meningkat tanpa perantara panjang.",
    link: "/login",
  },
  {
    index: 1,
    title:
      "Di Jakarta, konsumen apartemen menggunakan paket langganan mingguan untuk menerima buah segar langsung dari petani mitra dengan jadwal pengiriman pasti.",
    link: "/login",
  },
  {
    index: 1,
    title:
      "Di Yogyakarta, petani cabai memanfaatkan data permintaan untuk menentukan volume panen, mengurangi stok terbuang, dan menjaga harga tetap stabil.",
    link: "/login",
  },
];

import larrow from "../../assets/icon3.svg";
import SectionTitle from "../ui/SectionTitle.astro";
---

<Section id="cases">
  <SectionTitle
    sectionTitle="Contoh Implementasi"
    description="Ringkasan penggunaan PanenLangsung untuk mempertemukan petani dan konsumen secara langsung di berbagai kota."
  />
  <div class="flex flex-col lg:flex-row justify-between rounded-[45px] p-1">
    {
      cards.map((card) => (
        <Card>
          <div class="flex p-[60px] h-full bg-dark text-gray rounded-[45px] m-[1px]">
            <div class="flex flex-col gap-5">
              <p>{card.title}</p>
              <a href={card.link} class="flex items-center gap-[15px]">
                <span class="text-green">Lihat Detail</span>
                <picture>
                  <Image src={larrow} alt="Arrow pointing up right" />
                </picture>
              </a>
            </div>
          </div>
        </Card>
      ))
    }
  </div>
</Section>
