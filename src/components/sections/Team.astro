---
import SectionTitle from "../ui/SectionTitle.astro";
import TeamCard from "../ui/TeamCard.astro";
import Section from "./Section.astro";

const description =
  "Tim lintas fungsi yang mendukung operasional marketplace, pemberdayaan petani, dan pengalaman belanja konsumen";

// Team images
import p1 from "../../assets/team/t1.png";
import p2 from "../../assets/team/t2.png";
import p3 from "../../assets/team/t3.png";
import p4 from "../../assets/team/t4.png";
import p5 from "../../assets/team/t5.png";
import p6 from "../../assets/team/t6.png";

const team = [
  {
    pic: p1,
    name: "Rizky Pratama",
    role: "Head of Marketplace Operations",
    description:
      "Memimpin strategi operasional untuk memperluas jaringan petani dan menjaga kualitas transaksi harian.",
    link: "https://linkedin.com",
  },
  {
    pic: p2,
    name: "Nadia Lestari",
    role: "Lead Supply Chain",
    description:
      "Mengawal proses pengemasan dan pengiriman agar hasil panen sampai cepat, segar, dan tepat waktu.",
    link: "https://linkedin.com",
  },
  {
    pic: p3,
    name: "Dimas Anugrah",
    role: "Product Growth Analyst",
    description:
      "Menganalisis perilaku pembelian untuk membantu petani menentukan produk dan harga yang kompetitif.",
    link: "https://linkedin.com",
  },
  {
    pic: p4,
    name: "Maya Kurnia",
    role: "Quality Assurance Lead",
    description:
      "Memastikan standar mutu produk dan kemasan tetap terjaga sebelum hasil panen dikirim ke pelanggan.",
    link: "https://linkedin.com",
  },
  {
    pic: p5,
    name: "Farhan Akbar",
    role: "Engineering Manager",
    description:
      "Membangun sistem transaksi, pelacakan pesanan, dan dasbor penjualan yang stabil dan mudah digunakan.",
    link: "https://linkedin.com",
  },
  {
    pic: p6,
    name: "Intan Maheswari",
    role: "Community Partnership",
    description:
      "Mendampingi petani dan komunitas lokal agar onboarding platform berjalan lancar dan berkelanjutan.",
    link: "https://linkedin.com",
  },
];
---

<Section id="about">
  <div class="mt-[140px]">
    <SectionTitle sectionTitle="Tim Inti" description={description} />
    <div
      class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 grid-rows-2 gap-10"
    >
      {
        team.map((member, index) => (
          <TeamCard
            key={index}
            pic={member.pic}
            name={member.name}
            role={member.role}
            description={member.description}
            link={member.link}
          />
        ))
      }
    </div>
    <div class="flex justify-end mt-10">
      <button class="btn-primary">Lihat Profil Tim</button>
    </div>
  </div>
</Section>
